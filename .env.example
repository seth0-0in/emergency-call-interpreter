# =============================================================================
# 119 외국인 신고자 실시간 통번역 시스템 — 환경변수 템플릿
# =============================================================================
# 이 파일은 `.env.example` — 안전한 placeholder 만 들어 있다.
# 실제 운영/개발 값은 `.env.local` (gitignore 대상) 에 복사해 채워 넣는다.
#
#   cp .env.example .env.local
#   # → .env.local 을 편집해 실제 호스트/모델/키 주입
#
# 빌드 시 Vite 는 `VITE_*` 접두사가 붙은 변수만 클라이언트에 노출한다.
# 그 외 변수(EMS_* 등) 는 백엔드(`backend/ems_realtime.py`) 가 컨테이너 env 로
# 읽으므로, 이 파일에 적혀 있어도 프론트 번들에는 포함되지 않는다.
#
# 자리표시자:
#   <LLM_HOST>      — LLM 게이트웨이 호스트
#   <STT_HOST>      — STT 게이트웨이 호스트
#   <TTS_HOST>      — TTS 게이트웨이 호스트
#   <DIARIZE_HOST>  — 화자분리 STT 게이트웨이 호스트
#   <API_HOST>      — 백엔드 라우터가 노출되는 호스트
# =============================================================================


# ----- 백엔드 (backend/ems_realtime.py) ------------------------------------
# 컨테이너 env 또는 docker compose `environment` 로 주입한다.

# 외부 게이트웨이 URL (OpenAI-compatible /v1/* 엔드포인트)
EMS_STT_URL=https://<STT_HOST>/stt/v1/audio/transcriptions
EMS_STT_MODEL=cohere-transcribe
EMS_DIARIZE_URL=https://<DIARIZE_HOST>/v1/audio/transcriptions
EMS_LLM_URL=https://<LLM_HOST>/llm/v1/chat/completions
EMS_LLM_MODEL=example-llm-model
EMS_TTS_URL=https://<TTS_HOST>/tts/v1/audio/speech
EMS_TTS_MODEL=example-tts-model

# 인증 — 우선순위 EMS_LLM_API_KEY → JB_LLM_API_KEY → OPENAI_API_KEY → 파일 폴백.
# 키 값을 절대 이 파일에 적지 말 것 (커밋 사고 방지). `.env.local` 또는 컨테이너
# secret 으로만 주입한다.
EMS_LLM_API_KEY=
JB_LLM_API_KEY=
OPENAI_API_KEY=
EMS_LLM_API_KEY_FILE=/run/secrets/ems_llm_api_key
EMS_LLM_AUTH_REQUIRED=false
# true 면 운영 게이트웨이가 자체 인증을 수행해 Authorization 헤더 미부착이 필요한 환경.
EMS_LLM_AUTH_BYPASS=false

# 보안 / 네트워크
EMS_SSL_VERIFY=false
EMS_HTTP_TIMEOUT=60
EMS_STT_TIMEOUT=180
EMS_MIN_AUDIO_BYTES=1024

# 실시간 pending 버퍼 / STT 힌트
EMS_REALTIME_PENDING_ENABLED=true
EMS_REALTIME_PENDING_MIN_WORDS=1
EMS_REALTIME_PENDING_MAX_AGE_SEC=8.0
EMS_REALTIME_PENDING_MAX_TEXT_CHARS=400
EMS_REALTIME_PENDING_FORCE_COMMIT_MS=6000
EMS_STT_USE_LANGUAGE_HINT=true


# ----- 프론트엔드 빌드 / dev 서버 ------------------------------------------
# vite 가 dev 서버 부팅 시 / 빌드 시 읽는 값.

# vite dev 의 `/api` forward 토글 (로컬 백엔드 실행 시 1 로 설정).
VITE_EMS_LOCAL_API=0

# vite dev proxy 의 forward 대상 — 운영 빌드(same-origin)에서는 사용되지 않는다.
VITE_API_PROXY_TARGET=https://<API_HOST>
VITE_STT_PROXY_TARGET=https://<STT_HOST>
VITE_LLM_PROXY_TARGET=https://<LLM_HOST>
VITE_TTS_PROXY_TARGET=https://<TTS_HOST>
VITE_DIARIZE_PROXY_TARGET=https://<DIARIZE_HOST>

# 프론트가 LLM/TTS 호출 시 body 의 model 필드에 보낼 값.
# 백엔드의 EMS_LLM_MODEL / EMS_TTS_MODEL 과 일치시킨다.
VITE_LLM_MODEL=example-llm-model
VITE_TTS_MODEL=example-tts-model

# 정적 자산 base path (vite `base` 옵션). 운영 배포 경로에 맞춘다.
VITE_PUBLIC_BASE=/static/119/

# dev 한정 — vite proxy 가 `/translate`, `/llm` 요청에 Bearer 부착.
# 운영 빌드에는 노출되지 않는다 (`VITE_*` 가 아니므로).
JB_LLM_API_KEY=
